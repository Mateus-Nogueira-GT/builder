# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NextAuth
NEXTAUTH_SECRET=gere-um-segredo-forte-aqui
NEXTAUTH_URL=http://localhost:3000

# Wix OAuth (opcional — para fluxo OAuth em vez de API Key manual)
WIX_CLIENT_ID=your-wix-app-client-id
WIX_CLIENT_SECRET=your-wix-app-client-secret

# OpenAI (para geração de conteúdo com IA)
OPENAI_API_KEY=your-openai-api-key
