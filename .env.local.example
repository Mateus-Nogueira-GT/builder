# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NextAuth
NEXTAUTH_SECRET=gere-um-segredo-forte-aqui
NEXTAUTH_URL=http://localhost:3000

# Wix OAuth (obrigatório — para criar sites na conta do usuário)
WIX_OAUTH_APP_ID=your-wix-app-id
WIX_OAUTH_APP_SECRET=your-wix-app-secret
NEXT_PUBLIC_WIX_APP_ID=your-wix-app-id

# Wix Admin (para operações account-level como instalar app em sites)
WIX_ADMIN_API_KEY=your-admin-api-key
WIX_ACCOUNT_ID=your-account-id

# OpenAI (para geração de conteúdo com IA)
OPENAI_API_KEY=your-openai-api-key
